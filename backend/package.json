{
  "name": "shopsmart-backend",
  "version": "1.0.0",
  "description": "Express API for ShopSmart",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:pm2": "pm2-runtime start ecosystem.config.cjs",
    "dev": "nodemon src/index.js",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\" \"prisma/**/*.js\"",
    "test": "jest --runInBand",
